# Cabeceras servidas por Cloudflare Pages.
# Reglas más específicas se suman a las de /*.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

# HTML: siempre revalidar (el middleware inyecta OG/contenido según ?id).
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# El service worker no debe cachearse: así los clientes ven la versión nueva.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Estáticos inmutables (nombre estable): caché larga.
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
/favicon-96.png
  Cache-Control: public, max-age=31536000, immutable
/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable
/og.png
  Cache-Control: public, max-age=31536000, immutable
/manifest.json
  Cache-Control: public, max-age=86400
